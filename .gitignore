# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local debug and ad-hoc scripts
debug*.js
debug_*.txt
clean_orphaned.js
npm_audit.txt
.aider*

# ad-hoc test/dump/insert scripts (NUNCA versionar - podem conter segredos ou PII)
temp_*.js
test.js
test2.js
test-*.ts
check.js
setup-storage.js
clientes_dump*.html
clientes_debug*.html
*_dump.html
*_debug.html
analyze-dump.ts

# development-only agent context and design handoff
/.agents/
/.ai/
/.claude/
/.junie/
/design_handoff_gestor_master/
/logo/
/scripts/

# local planning, documentation and reference artifacts
/*.md
/*.html
/*.zip
/skills-lock.json
/components.json
/eslint.config.mjs
/vercel.json

# ad-hoc database and diagnostic files kept outside canonical Supabase assets
/*.sql
/test_*.js
/apply_*.js
/fix_*.js
/patch_*.js

# source-level development tests are not part of the production repository
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# unused starter assets from the Next.js scaffold
/public/file.svg
/public/globe.svg
/public/next.svg
/public/vercel.svg
/public/window.svg
